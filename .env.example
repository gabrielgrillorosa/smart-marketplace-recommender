# Smart Marketplace Recommender — Environment Variables
# Copy this file to .env before running docker compose up:
#   cp .env.example .env
#
# Infrastructure services (postgres, neo4j) start with these safe defaults.
# AI features that require OPENROUTER_API_KEY will degrade gracefully without it.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5433
POSTGRES_DB=marketplace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
# Reduce to 256m on machines with less than 8 GB RAM
NEO4J_HEAP_MAX=512m

# ── API Service (Spring Boot) ──────────────────────────────────────────────────
API_SERVICE_PORT=8080
SPRING_PROFILES_ACTIVE=dev
# M20 — same value as ai-service (default: no auto-train on checkout)
CHECKOUT_ENQUEUE_TRAINING=false

# ── AI Service (Fastify / Node.js) ────────────────────────────────────────────
AI_SERVICE_PORT=3001
# Embedding model — multilingual, supports PT/ES/EN (50+ languages), 384 dims — ~120MB, cached in container
# Switched from all-MiniLM-L6-v2 (English-only) to support Portuguese queries
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── OpenRouter LLM Gateway (required for RAG chat — M3) ──────────────────────
# Get your free key at: https://openrouter.ai
OPENROUTER_API_KEY=
# LLM model used by OpenRouter for RAG chat inference (free tier)
LLM_MODEL=openai/gpt-oss-20b:free

# ── Internal service URLs (used by Next.js server-side proxies) ───────────────
AI_SERVICE_URL=http://ai-service:3001
API_SERVICE_URL=http://api-service:8080


RECENT_PURCHASE_WINDOW_DAYS=1
# ── Recommendation Scoring Weights (M4) ───────────────────────────────────────
# Final score = NEURAL_WEIGHT * neuralScore + SEMANTIC_WEIGHT * semanticScore
NEURAL_WEIGHT=0.7
SEMANTIC_WEIGHT=0.3
# M17 P1 — recency re-rank (0 = off). rankScore = finalScore + RECENCY_RERANK_WEIGHT * recencySimilarity
RECENCY_RERANK_WEIGHT=0.15
RECENCY_ANCHOR_COUNT=1

ADMIN_API_KEY=dev-local-key
NEXT_PUBLIC_ADMIN_API_KEY=dev-local-key

AUTO_HEAL_MODEL=true
# Set to false to skip the auto-seed cold-start probe (useful in real production where
# data is restored from backups or migrated by a separate job).
AUTO_SEED_ON_BOOT=true


# M21 — profile pooling (Docker default: attention_learned; JSON under /app/data in container)
PROFILE_POOLING_MODE=attention_light
PROFILE_POOLING_HALF_LIFE_DAYS=30
# T = softmax temperature over the logits (attention_light / attention_learned). Empty or inf => uniform weights (mean pooling).
PROFILE_POOLING_ATTENTION_TEMPERATURE=0.3
# Only the N most recent purchases enter the pooling step before softmax; 0 = all purchases.
PROFILE_POOLING_ATTENTION_MAX_ENTRIES=4
PROFILE_POOLING_ATTENTION_LEARNED_JSON_PATH=./data/attention-learned.json
NEURAL_LOSS_MODE=bce

# M21 — cron: full MLP daily train + optional attention-learned JSON refresh only
ENABLE_DAILY_TRAIN=true
DAILY_TRAIN_CRON=0 2 * * *
ATTENTION_LEARNED_REFRESH_CRON=
ATTENTION_LEARNED_NEGATIVES_PER_POSITIVE=2

M22_ENABLED=true
M22_STRUCTURAL=true
M22_IDENTITY=false

NEURAL_ARCH_PROFILE=deep256
# M23 — negative sampling redesign for training only.
# stratified = new M23 sampler (minimal soft cleanup + hard/medium/easy buckets).
# legacy = pre-M23 behavior and the rollback path.
NEGATIVE_SAMPLING_MODE=stratified
# In stratified mode, candidates above this cosine similarity are treated as near-duplicates
# and removed from the negative pool during soft cleanup.
SOFT_NEGATIVE_MAX_SIM=0.92
# Lower bound for the hard bucket in stratified mode.
HARD_NEGATIVE_MIN_SIM=0.70
# Lower bound for the medium bucket in stratified mode; values below this fall into the easy bucket.
MEDIUM_NEGATIVE_MIN_SIM=0.40
# Number of repeated runs per M23 benchmark configuration (minimum 2). Used by the offline benchmark harness.
M23_BENCHMARK_RUNS=2

# Legacy pre-M23 similarity filter. This still applies when NEGATIVE_SAMPLING_MODE=legacy.
SOFT_NEGATIVE_SIM_THRESHOLD=0.75

