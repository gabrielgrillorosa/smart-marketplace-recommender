# Smart Marketplace Recommender — Environment Variables
# Copy this file to .env before running docker compose up:
#   cp .env.example .env
#
# Infrastructure services (postgres, neo4j) start with these safe defaults.
# AI features that require OPENROUTER_API_KEY will degrade gracefully without it.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Host port mapping (use 5433 if 5432 is already allocated on the host)
POSTGRES_HOST_PORT=5433
POSTGRES_DB=marketplace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
# Reduce to 256m on machines with less than 8 GB RAM
NEO4J_HEAP_MAX=512m

# ── API Service (Spring Boot) ──────────────────────────────────────────────────
API_SERVICE_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ── AI Service (Fastify / Node.js) ────────────────────────────────────────────
AI_SERVICE_PORT=3001
# Internal port used by the ai-service process (must match AI_SERVICE_PORT)
PORT=3001
# Embedding model — runs locally inside the container via @huggingface/transformers (no API key required)
# Uses sentence-transformers/all-MiniLM-L6-v2 (384 dims) — downloaded on first startup (~90MB)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── OpenRouter LLM Gateway (required for RAG chat — M3) ──────────────────────
# Get your free key at: https://openrouter.ai
OPENROUTER_API_KEY=
# LLM model used by OpenRouter for RAG chat inference (free tier)
# meta-llama/llama-3.2-3b-instruct:free — 3B params, 131K context, fast, free
LLM_MODEL=meta-llama/llama-3.2-3b-instruct:free

# ── Recommendation Scoring Weights (M4) ───────────────────────────────────────
# Final score = NEURAL_WEIGHT * neuralScore + SEMANTIC_WEIGHT * semanticScore
NEURAL_WEIGHT=0.6
SEMANTIC_WEIGHT=0.4

# ── Admin Security (M7) ────────────────────────────────────────────────────────
# Protects POST /model/train and POST /embeddings/generate against unauthorized use.
# Leave empty for local development — auth is disabled with a startup warning.
# Set to a strong secret before any public deploy.
ADMIN_API_KEY=
