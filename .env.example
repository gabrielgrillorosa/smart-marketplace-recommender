# Smart Marketplace Recommender — Environment Variables
# Copy this file to .env before running docker compose up:
#   cp .env.example .env
#
# Infrastructure services (postgres, neo4j) start with these safe defaults.
# AI features that require OPENROUTER_API_KEY will degrade gracefully without it.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Host port mapping (use 5433 if 5432 is already allocated on the host)
POSTGRES_HOST_PORT=5433
POSTGRES_DB=marketplace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
# Reduce to 256m on machines with less than 8 GB RAM
NEO4J_HEAP_MAX=512m

# ── API Service (Spring Boot) ──────────────────────────────────────────────────
API_SERVICE_PORT=8080
SPRING_PROFILES_ACTIVE=dev
# M20 / ADR-067 — must match ai-service. false = checkout only syncs orders→Neo4j; no auto MLP train (use manual train + metrics).
CHECKOUT_ENQUEUE_TRAINING=false

# ── AI Service (Fastify / Node.js) ────────────────────────────────────────────
AI_SERVICE_PORT=3001
# Internal port used by the ai-service process (must match AI_SERVICE_PORT)
PORT=3001
# Embedding model — runs locally inside the container via @huggingface/transformers (no API key required)
# Uses sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 (384 dims, 50+ languages) — ~120MB cached
# Supports Portuguese, Spanish, English and other languages for semantic search and RAG
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── OpenRouter LLM Gateway (required for RAG chat — M3) ──────────────────────
# Get your free key at: https://openrouter.ai
OPENROUTER_API_KEY=
# LLM model used by OpenRouter for RAG chat inference (free tier)
# meta-llama/llama-3.2-3b-instruct:free — 3B params, 131K context, fast, free
LLM_MODEL=meta-llama/llama-3.2-3b-instruct:free
# Base URL for the OpenRouter API — override to point to Groq, Together, or local Ollama
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Internal service URLs (used by Next.js server-side proxies) ───────────────
# These are resolved inside the Docker network — do not change unless renaming services
AI_SERVICE_URL=http://ai-service:3001
API_SERVICE_URL=http://api-service:8080

# ── Recommendation Scoring Weights (M4) ───────────────────────────────────────
# Final score = NEURAL_WEIGHT * neuralScore + SEMANTIC_WEIGHT * semanticScore
NEURAL_WEIGHT=0.6
SEMANTIC_WEIGHT=0.4
# M17 P1 — optional re-rank after hybrid scores (ADR-062). 0 = disabled (order = finalScore + tie-breaks).
# rankScore = finalScore + RECENCY_RERANK_WEIGHT * recencySimilarity (max cosine to last N purchased embeddings).
RECENCY_RERANK_WEIGHT=0
# Distinct recent confirmed purchases to use as anchors (1–10).
RECENCY_ANCHOR_COUNT=1

# M21 T1 — neural training loss / head (ADR-071). bce = legacy sigmoid + binaryCrossentropy; pairwise = linear head + ranking loss (restart ai-service + retrain to apply).
NEURAL_LOSS_MODE=bce

# M22 — hybrid sparse item tower (ADR-074). Master off = training/inference stay on legacy 768-d concat; enable + retrain to produce m22 checkpoint + m22-item-manifest.json.
# M22_IDENTITY=true requires M22_STRUCTURAL=true (ai-service fails fast at boot otherwise).
# Docker Compose: keep M22_* in this file — compose no longer re-declares them with `${VAR:-false}` (that could force false when the host env omits them).
M22_ENABLED=false
M22_STRUCTURAL=false
M22_IDENTITY=false

# M17 P2 / M21 — client profile pooling (ADR-065, ADR-072).
# mean | exp | attention_light | attention_learned (default in Docker: attention_learned).
PROFILE_POOLING_MODE=attention_learned
PROFILE_POOLING_HALF_LIFE_DAYS=30
# attention_light / attention_learned optional caps (see ai-service/README.md)
# PROFILE_POOLING_ATTENTION_TEMPERATURE=
# PROFILE_POOLING_ATTENTION_MAX_ENTRIES=0
# Optional override; in Docker the JSON is persisted on volume ai-attention-learned-data at /app/data/attention-learned.json
# PROFILE_POOLING_ATTENTION_LEARNED_JSON_PATH=

# M21 — daily full MLP train + optional attention JSON-only refresh (CronScheduler)
ENABLE_DAILY_TRAIN=true
DAILY_TRAIN_CRON=0 2 * * *
# Empty = disabled. Example: 30 2 * * 1,4 — Mon/Thu 02:30 UTC
ATTENTION_LEARNED_REFRESH_CRON=
# Negatives per positive when building the attention_learned JSON dataset (boot, admin, post-train hook)
ATTENTION_LEARNED_NEGATIVES_PER_POSITIVE=2

# M16 — days after a confirmed purchase during which the SKU is shown but not in the neural-ranked block
RECENT_PURCHASE_WINDOW_DAYS=7
# Startup self-healing for missing model (M12). Use false only in unit/E2E tests.
AUTO_HEAL_MODEL=true
# Training negatives (similarity threshold for soft negatives)
SOFT_NEGATIVE_SIM_THRESHOLD=0.65

# ── Admin Security (M7) ────────────────────────────────────────────────────────
# Protects POST /model/train and POST /embeddings/generate against unauthorized use.
# Leave empty for local development — auth is disabled with a startup warning.
# Set to a strong secret before any public deploy.
ADMIN_API_KEY=
# ^ Leave empty to disable auth check (dev only).
# Required to call POST /api/v1/model/train (trigger model retraining).
# Example: ADMIN_API_KEY=my-secret-key
